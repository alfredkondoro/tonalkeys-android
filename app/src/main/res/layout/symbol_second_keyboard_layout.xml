<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1B1B1B"
    android:padding="6dp">

    <!-- Row 1: 1–0 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <Button android:id="@+id/key_1" android:text="1" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_2" android:text="2" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_3" android:text="3" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_4" android:text="4" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_5" android:text="5" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_6" android:text="6" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_7" android:text="7" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_8" android:text="8" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_9" android:text="9" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
        <Button android:id="@+id/key_0" android:text="0" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp" android:layout_height="42dp"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <Button android:id="@+id/key_backtick" android:text="`" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_tilde" android:text="~" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_backslash" android:text="\\" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_pipe" android:text="|" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_left_curly" android:text="{" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_right_curly" android:text="}" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_euro" android:text="€" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_pound" android:text="£" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_yen" android:text="¥" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_won" android:text="₩" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <Button android:id="@+id/key_dot_center" android:text="◦" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_dot_bold" android:text="•" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_circle" android:text="○" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_circle_filled" android:text="●" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_square" android:text="■" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_spade" android:text="♠" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_heart" android:text="♥" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_diamond" android:text="♦" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_club" android:text="♣" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <Button android:id="@+id/key_symbol_shiftback" android:text="2/2" style="@style/KeyButton" android:layout_weight="1.3" android:layout_width="0dp"/>
        <Button android:id="@+id/key_star" android:text="★" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_square_hollow" android:text="☐" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_gear" android:text="⚙" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_angle_left" android:text="«" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_angle_right" android:text="»" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_info" android:text="ℹ" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_question_inverted" android:text="¿" style="@style/KeyButton" android:layout_weight="1" android:layout_width="0dp"/>
        <Button android:id="@+id/key_backspace" android:text="⌫" style="@style/KeyButton" android:layout_weight="1.5" android:layout_width="0dp"/>
    </LinearLayout>

    <!-- Row 5 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/key_symbols" android:layout_width="0dp" android:layout_weight="1" android:text="ABC" style="@style/KeyButton"/>
        <Button android:id="@+id/key_emoji" android:layout_width="0dp" android:layout_weight="1" android:text="🦒" style="@style/KeyButton"/>
        <Button android:id="@+id/key_comma" android:layout_width="0dp" android:layout_weight="1" android:text="," style="@style/KeyButton"
            tools:ignore="DuplicateIds" />
        <Button android:id="@+id/key_space" android:layout_width="0dp" android:layout_weight="3" android:text="NAFASI" style="@style/KeyButton"/>
        <Button android:id="@+id/key_dot" android:layout_width="0dp" android:layout_weight="1" android:text="." style="@style/KeyButton"/>
        <Button android:id="@+id/key_enter" android:layout_width="0dp" android:layout_weight="1" android:text="⏎" style="@style/KeyButton"/>
    </LinearLayout>

</LinearLayout>
