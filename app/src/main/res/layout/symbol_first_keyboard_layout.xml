<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1B1B1B"
    android:padding="6dp">

    <!-- Row 1: Numbers 1–0 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">
        <Button android:id="@+id/key_1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="1" style="@style/KeyButton"/>
        <Button android:id="@+id/key_2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="2" style="@style/KeyButton"/>
        <Button android:id="@+id/key_3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="3" style="@style/KeyButton"/>
        <Button android:id="@+id/key_4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="4" style="@style/KeyButton"/>
        <Button android:id="@+id/key_5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="5" style="@style/KeyButton"/>
        <Button android:id="@+id/key_6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="6" style="@style/KeyButton"/>
        <Button android:id="@+id/key_7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="7" style="@style/KeyButton"/>
        <Button android:id="@+id/key_8" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="8" style="@style/KeyButton"/>
        <Button android:id="@+id/key_9" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="9" style="@style/KeyButton"/>
        <Button android:id="@+id/key_0" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:minHeight="0dp" android:text="0" style="@style/KeyButton"/>
    </LinearLayout>

    <!-- Row 2: q to p -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">
        <Button android:id="@+id/key_add" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="+" style="@style/KeyButton"/>
        <Button android:id="@+id/key_multiply" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="×" style="@style/KeyButton"/>
        <Button android:id="@+id/key_division" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="÷" style="@style/KeyButton"/>
        <Button android:id="@+id/key_equals" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="=" style="@style/KeyButton"/>
        <Button android:id="@+id/key_backslash" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="/" style="@style/KeyButton"/>
        <Button android:id="@+id/key_lowdash" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="_" style="@style/KeyButton"/>
        <Button android:id="@+id/key_leftpointbracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="&lt;" style="@style/KeyButton"/>
        <Button android:id="@+id/key_rightpointbracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="&gt;" style="@style/KeyButton"/>
        <Button android:id="@+id/key_leftsquarebracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="[" style="@style/KeyButton"/>
        <Button android:id="@+id/key_rightsquarebracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="]" style="@style/KeyButton"/>
    </LinearLayout>

    <!-- Row 3: a to l -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <Button android:id="@+id/key_exclamation" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="!" style="@style/KeyButton"/>
        <Button android:id="@+id/key_mail" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="&#64;" style="@style/KeyButton"/>
        <Button android:id="@+id/key_hashtag" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="#" style="@style/KeyButton"/>
        <Button android:id="@+id/key_dollarsign" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="$" style="@style/KeyButton"/>
        <Button android:id="@+id/key_percent" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="%" style="@style/KeyButton"/>
        <Button android:id="@+id/key_exponent" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="^" style="@style/KeyButton"/>
        <Button android:id="@+id/key_ampersand" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="&amp;" style="@style/KeyButton"/>
        <Button android:id="@+id/key_asterik" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="*" style="@style/KeyButton"/>
        <Button android:id="@+id/key_leftbracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="(" style="@style/KeyButton"/>
        <Button android:id="@+id/key_rightbracket" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text=")" style="@style/KeyButton"/>
    </LinearLayout>




    <!-- Row 4: shift z to m delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <Button android:id="@+id/key_shiftforward"
            android:layout_weight="1.3"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginEnd="27dp"
            android:text="1/2"
            style="@style/KeyButton"/>

        <Button android:id="@+id/key_dash" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="-" style="@style/KeyButton"/>
        <Button android:id="@+id/key_singleapo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="'" style="@style/KeyButton"/>
        <Button android:id="@+id/key_doubleapo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="&quot;" style="@style/KeyButton"/>
        <Button android:id="@+id/key_colon" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text=":" style="@style/KeyButton"/>
        <Button android:id="@+id/key_semicolon" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text=";" style="@style/KeyButton"/>
        <Button android:id="@+id/key_comma" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:text="," style="@style/KeyButton"/>
        <Button android:id="@+id/key_question" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:layout_marginEnd="7dp" android:text="&#63;" style="@style/KeyButton"/>

        <Button android:id="@+id/key_backspace"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="55dp"
            android:text="⌫"
            style="@style/KeyButton"/>
    </LinearLayout>


    <!-- Row 5: bottom row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/key_symbols" android:layout_width="0dp" android:layout_weight="1" android:text="ABC" style="@style/KeyButton"/>
        <Button android:id="@+id/key_emoji" android:layout_width="0dp" android:layout_weight="1" android:text="🦒" style="@style/KeyButton"/>
        <Button android:id="@+id/key_comma" android:layout_width="0dp" android:layout_weight="1" android:text="," style="@style/KeyButton"
            tools:ignore="DuplicateIds" />
        <Button android:id="@+id/key_space" android:layout_width="0dp" android:layout_weight="3" android:text="NAFASI" style="@style/KeyButton"/>
        <Button android:id="@+id/key_dot" android:layout_width="0dp" android:layout_weight="1" android:text="." style="@style/KeyButton"/>
        <Button android:id="@+id/key_enter" android:layout_width="0dp" android:layout_weight="1" android:text="⏎" style="@style/KeyButton"/>
    </LinearLayout>

</LinearLayout>
